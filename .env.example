# App ports
BACKEND_PORT=8080
FRONTEND_PORT=8080
FRONTEND_HOST_PORT=8081

# Logging
RUST_LOG=info

# PostgreSQL
POSTGRES_DB=blog002
POSTGRES_USER=blog002
POSTGRES_PASSWORD=blog002
POSTGRES_PORT=5432
DATABASE_URL=postgres://blog002:blog002@postgres:5432/blog002
DB_MAX_CONNECTIONS=10
DB_CONNECT_TIMEOUT_SECS=5

# MinIO / S3-compatible storage
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=blog002-local
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
